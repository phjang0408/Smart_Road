<Window x:Class="Smart_Road.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="도심형 스마트 교차로 대시보드" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" Closing="Window_Closing"
        Background="#121212" FontFamily="Malgun Gothic">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#434360"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.3" ShadowDepth="3"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*" />
            <ColumnDefinition Width="4*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,20,0">
            <Grid>
                <TextBlock Text="Live Intersection Map" Foreground="#A0A0B0" FontSize="18" FontWeight="Bold" VerticalAlignment="Top" HorizontalAlignment="Left"/>

                <Viewbox Margin="0,30,0,50">
                    <Canvas x:Name="canvasIntersection" Width="500" Height="500">
                        <Rectangle Width="500" Height="500" Fill="#2A2A35" RadiusX="10" RadiusY="10"/>
                        <Rectangle Fill="#3A3A48" Width="120" Height="500" Canvas.Left="190" Canvas.Top="0" />
                        <Rectangle Fill="#3A3A48" Width="500" Height="120" Canvas.Left="0" Canvas.Top="190" />

                        <!-- 블랙아이스 이펙트 (오버레이) -->
                        <Rectangle x:Name="rectBlackIceOverlay" Width="500" Height="500" Fill="#E0F2F7" Opacity="0" RadiusX="10" RadiusY="10" Panel.ZIndex="2"/>

                        <Line X1="250" Y1="0" X2="250" Y2="190" Stroke="#FFD700" StrokeThickness="3" StrokeDashArray="4 4" />
                        <Line X1="250" Y1="310" X2="250" Y2="500" Stroke="#FFD700" StrokeThickness="3" StrokeDashArray="4 4" />
                        <Line X1="0" Y1="250" X2="190" Y2="250" Stroke="#FFD700" StrokeThickness="3" StrokeDashArray="4 4" />
                        <Line X1="310" Y1="250" X2="500" Y2="250" Stroke="#FFD700" StrokeThickness="3" StrokeDashArray="4 4" />

                        <Border Canvas.Left="146" Canvas.Top="123" Background="#202030" CornerRadius="5" Padding="5,2" BorderBrush="#505070" BorderThickness="1" Panel.ZIndex="10">
                            <TextBlock x:Name="txtCarsN" Text="0대" Foreground="#4CAF50" FontWeight="Bold" FontSize="14" />
                        </Border>
                        <Border Canvas.Left="320" Canvas.Top="353" Background="#202030" CornerRadius="5" Padding="5,2" BorderBrush="#505070" BorderThickness="1" Panel.ZIndex="10">
                            <TextBlock x:Name="txtCarsS" Text="0대" Foreground="#4CAF50" FontWeight="Bold" FontSize="14" />
                        </Border>
                        <Border Canvas.Left="354" Canvas.Top="160" Background="#202030" CornerRadius="5" Padding="5,2" BorderBrush="#505070" BorderThickness="1" Panel.ZIndex="10">
                            <TextBlock x:Name="txtCarsE" Text="0대" Foreground="#4CAF50" FontWeight="Bold" FontSize="14" />
                        </Border>
                        <Border Canvas.Left="109" Canvas.Top="323" Background="#202030" CornerRadius="5" Padding="5,2" BorderBrush="#505070" BorderThickness="1" Panel.ZIndex="10">
                            <TextBlock x:Name="txtCarsW" Text="0대" Foreground="#4CAF50" FontWeight="Bold" FontSize="14" />
                        </Border>

                        <!-- 도로 방향 화살표 -->
                        <TextBlock Canvas.Left="265" Canvas.Top="308" Text="↑" FontSize="36" Foreground="#2196F3" FontWeight="Bold" Panel.ZIndex="3"/>
                        <TextBlock Canvas.Left="201" Canvas.Top="137" Text="↓" FontSize="36" Foreground="#2196F3" FontWeight="Bold" Panel.ZIndex="3" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Canvas.Left="149" Canvas.Top="254" Text="→" FontSize="36" Foreground="#2196F3" FontWeight="Bold" Panel.ZIndex="3"/>
                        <TextBlock Canvas.Left="310" Canvas.Top="190" Text="←" FontSize="36" Foreground="#2196F3" FontWeight="Bold" Panel.ZIndex="3" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                        <!-- 신호등: N (북쪽) -->
                        <Border Canvas.Left="141" Canvas.Top="152" Background="#111" Padding="2" CornerRadius="3" Panel.ZIndex="5">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="lightN_Red" Fill="#FF3B30" Width="16" Height="16" Margin="2" />
                                <Ellipse x:Name="lightN_Green" Fill="#4CAF50" Width="16" Height="16" Margin="2" />
                            </StackPanel>
                        </Border>

                        <!-- 신호등: S (남쪽) -->
                        <Border Canvas.Left="315" Canvas.Top="324" Background="#111" Padding="2" CornerRadius="3" Panel.ZIndex="5">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="lightS_Red" Fill="#FF3B30" Width="16" Height="16" Margin="2" />
                                <Ellipse x:Name="lightS_Green" Fill="#4CAF50" Width="16" Height="16" Margin="2" />
                            </StackPanel>
                        </Border>

                        <!-- 신호등: E (동쪽) -->
                        <Border Canvas.Left="325" Canvas.Top="141" Background="#111" Padding="2" CornerRadius="3" Panel.ZIndex="5" HorizontalAlignment="Center" VerticalAlignment="Top">
                            <StackPanel Orientation="Vertical">
                                <Ellipse x:Name="lightE_Red" Fill="#FF3B30" Width="16" Height="16" Margin="2" />
                                <Ellipse x:Name="lightE_Green" Fill="#4CAF50" Width="16" Height="16" Margin="2" />
                            </StackPanel>
                        </Border>

                        <!-- 신호등: W (서쪽) -->
                        <Border Canvas.Left="151" Canvas.Top="314" Background="#111" Padding="2" CornerRadius="3" Panel.ZIndex="5">
                            <StackPanel Orientation="Vertical">
                                <Ellipse x:Name="lightW_Red" Fill="#FF3B30" Width="16" Height="16" Margin="2" />
                                <Ellipse x:Name="lightW_Green" Fill="#4CAF50" Width="16" Height="16" Margin="2" />
                            </StackPanel>
                        </Border>

                        <!-- 역주행 차량 경고 (중앙 교차로) -->
                        <Rectangle x:Name="rectWrongWayCar" Width="20" Height="20" Fill="#FF3B30" RadiusX="2" RadiusY="2" Canvas.Left="240" Canvas.Top="240" Visibility="Hidden" Panel.ZIndex="6">
                            <Rectangle.Effect>
                                <DropShadowEffect Color="#FF3B30" BlurRadius="8" Opacity="0.7" ShadowDepth="0"/>
                            </Rectangle.Effect>
                        </Rectangle>
                    </Canvas>
                </Viewbox>

                <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,0">
                    <TextBlock x:Name="txtSignalTimer" Text="다음 신호까지: 0.0초" Foreground="#A0A0B0" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <ProgressBar x:Name="pbSignalTimer" Height="8" Margin="30,5,30,0" Maximum="100" Value="0" Foreground="#4CAF50" Background="#2A2A35" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Column="1" Background="#121212">
            <!-- 그래프 섹션 -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="기온 &amp; 강수량" Foreground="#A0A0B0" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <Border Background="#1E1E2E" CornerRadius="5" Padding="5" Margin="0,0,0,10">
                        <Canvas x:Name="canvasGraph" Height="220"/>
                    </Border>

                    <TextBlock x:Name="txtGraphStats" Text="최고기온: - °C | 최저기온: - °C | 누적강수: - mm" Foreground="#707080" FontSize="11" Margin="0,0,0,10"/>

                    <Button x:Name="btnStartDay" Content="▶ 하루 시뮬레이션 시작" Height="40" Background="#4CAF50" Foreground="White" FontWeight="Bold" Click="BtnStartDay_Click"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Weather &amp; Environment" Foreground="#A0A0B0" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="기온" Foreground="#707080" FontSize="12"/>
                            <TextBlock x:Name="txtTemperature" Text="- °C" Foreground="White" FontSize="24" FontWeight="Bold"/>
                            <TextBlock Text="풍속" Foreground="#707080" FontSize="12" Margin="0,10,0,0"/>
                            <TextBlock x:Name="txtWindSpeed" Text="- m/s" Foreground="White" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="강수량" Foreground="#707080" FontSize="12"/>
                            <TextBlock x:Name="txtRainfall" Text="- mm/h" Foreground="White" FontSize="24" FontWeight="Bold"/>
                            <TextBlock Text="진입속도" Foreground="#707080" FontSize="12" Margin="0,10,0,0"/>
                            <TextBlock x:Name="txtVehicleSpeed" Text="- km/h" Foreground="White" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="System Status" Foreground="#A0A0B0" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>

                    <TextBlock Text="노면 상태" Foreground="#707080" FontSize="12" Margin="0,0,0,5"/>
                    <Border x:Name="bdRoadCondition" Background="#2D2D44" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                        <TextBlock x:Name="txtRoadCondition" Text="대기 중" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="활성 제어 모드" Foreground="#707080" FontSize="12" Margin="0,0,0,5"/>
                    <Border BorderBrush="#FF3B30" BorderThickness="1" Background="#201010" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                        <TextBlock x:Name="txtActiveControl" Text="정상 작동 중" Foreground="#4CAF50" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="안전도 평가" Foreground="#707080" FontSize="12" Margin="0,0,0,5"/>
                    <TextBlock x:Name="txtRoadSafetyScore" Text="Road Safety Score: - " Foreground="#707080" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

                    <TextBlock x:Name="txtWrongWay" Text="역주행: 없음" Foreground="#4CAF50" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="txtPedestrian" Text="잔류 보행자: 없음" Foreground="#4CAF50" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="txtAvgSpeed" Text="GPS 평균속도: - km/h" Foreground="#707080" FontSize="11" Margin="0,0,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" VerticalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="Manual Control &amp; Speed" Foreground="#A0A0B0" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>

                    <Button x:Name="btnToggleBlackIce" Content="블랙아이스 모드 강제 실행" Height="40" Margin="0,0,0,10" Background="#FF9500" Foreground="White"/>
                    <Button x:Name="btnToggleRushHour" Content="혼잡 시간 모드 해제" Height="40" Margin="0,0,0,10" Background="#6750A4" Foreground="White"/>
                    <Button x:Name="btnTriggerWrongWay" Content="🚨 역주행 시뮬레이션 발생" Height="40" Margin="0,0,0,10" Background="#FF3B30" Foreground="White"/>

                    <TextBlock Text="시뮬레이션 배속 설정" Foreground="#707080" FontSize="12" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnSpeed1x" Grid.Column="0" Content="1x (정상)" Height="35" Margin="0,0,5,0" Click="BtnSpeed1x_Click"/>
                        <Button x:Name="btnSpeed2x" Grid.Column="1" Content="2x" Height="35" Margin="5,0,5,0" Click="BtnSpeed2x_Click"/>
                        <Button x:Name="btnSpeed4x" Grid.Column="2" Content="4x" Height="35" Margin="5,0,0,0" Click="BtnSpeed4x_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>