<Window x:Class="Smart_Road.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="도심형 스마트 교차로 대시보드" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" Closing="Window_Closing"
        Background="#121212" FontFamily="Malgun Gothic">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#434360"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.3" ShadowDepth="3"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*" />
            <ColumnDefinition Width="4*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,20,0">
            <Grid>
                <TextBlock Text="Live Intersection Map" Foreground="#A0A0B0" FontSize="18" FontWeight="Bold" VerticalAlignment="Top" HorizontalAlignment="Left"/>

                <Viewbox Margin="0,30,0,50">
                    <Canvas x:Name="canvasIntersection" Width="500" Height="500">
                        <Rectangle Width="500" Height="500" Fill="#2A2A35" RadiusX="10" RadiusY="10"/>
                        <Rectangle Fill="#3A3A48" Width="120" Height="500" Canvas.Left="190" Canvas.Top="0" />
                        <Rectangle Fill="#3A3A48" Width="500" Height="120" Canvas.Left="0" Canvas.Top="190" />

                        <Line X1="250" Y1="0" X2="250" Y2="190" Stroke="#FFD700" StrokeThickness="3" StrokeDashArray="4 4" />
                        <Line X1="250" Y1="310" X2="250" Y2="500" Stroke="#FFD700" StrokeThickness="3" StrokeDashArray="4 4" />
                        <Line X1="0" Y1="250" X2="190" Y2="250" Stroke="#FFD700" StrokeThickness="3" StrokeDashArray="4 4" />
                        <Line X1="310" Y1="250" X2="500" Y2="250" Stroke="#FFD700" StrokeThickness="3" StrokeDashArray="4 4" />

                        <Border Canvas.Left="260" Canvas.Top="20" Background="#202030" CornerRadius="5" Padding="5,2" BorderBrush="#505070" BorderThickness="1" Panel.ZIndex="10">
                            <TextBlock x:Name="txtCarsN" Text="0대" Foreground="#4CAF50" FontWeight="Bold" FontSize="14" />
                        </Border>
                        <Border Canvas.Left="260" Canvas.Top="450" Background="#202030" CornerRadius="5" Padding="5,2" BorderBrush="#505070" BorderThickness="1" Panel.ZIndex="10">
                            <TextBlock x:Name="txtCarsS" Text="0대" Foreground="#4CAF50" FontWeight="Bold" FontSize="14" />
                        </Border>
                        <Border Canvas.Left="440" Canvas.Top="260" Background="#202030" CornerRadius="5" Padding="5,2" BorderBrush="#505070" BorderThickness="1" Panel.ZIndex="10">
                            <TextBlock x:Name="txtCarsE" Text="0대" Foreground="#4CAF50" FontWeight="Bold" FontSize="14" />
                        </Border>
                        <Border Canvas.Left="20" Canvas.Top="260" Background="#202030" CornerRadius="5" Padding="5,2" BorderBrush="#505070" BorderThickness="1" Panel.ZIndex="10">
                            <TextBlock x:Name="txtCarsW" Text="0대" Foreground="#4CAF50" FontWeight="Bold" FontSize="14" />
                        </Border>

                        <Border Canvas.Left="140" Canvas.Top="150" Background="#111" Padding="2" CornerRadius="3" Panel.ZIndex="5">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="lightNW_Red" Fill="#33FF3B30" Width="14" Height="14" Margin="2" />
                                <Ellipse x:Name="lightNW_Green" Fill="#4CAF50" Width="14" Height="14" Margin="2" />
                            </StackPanel>
                        </Border>
                        <Border Canvas.Left="320" Canvas.Top="150" Background="#111" Padding="2" CornerRadius="3" Panel.ZIndex="5">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="lightNE_Red" Fill="#33FF3B30" Width="14" Height="14" Margin="2" />
                                <Ellipse x:Name="lightNE_Green" Fill="#4CAF50" Width="14" Height="14" Margin="2" />
                            </StackPanel>
                        </Border>
                        <Border Canvas.Left="140" Canvas.Top="330" Background="#111" Padding="2" CornerRadius="3" Panel.ZIndex="5">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="lightSW_Red" Fill="#33FF3B30" Width="14" Height="14" Margin="2" />
                                <Ellipse x:Name="lightSW_Green" Fill="#4CAF50" Width="14" Height="14" Margin="2" />
                            </StackPanel>
                        </Border>
                        <Border Canvas.Left="320" Canvas.Top="330" Background="#111" Padding="2" CornerRadius="3" Panel.ZIndex="5">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="lightSE_Red" Fill="#33FF3B30" Width="14" Height="14" Margin="2" />
                                <Ellipse x:Name="lightSE_Green" Fill="#4CAF50" Width="14" Height="14" Margin="2" />
                            </StackPanel>
                        </Border>
                    </Canvas>
                </Viewbox>

                <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,0">
                    <TextBlock x:Name="txtSignalTimer" Text="다음 신호까지: 0.0초" Foreground="#A0A0B0" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <ProgressBar x:Name="pbSignalTimer" Height="8" Margin="30,5,30,0" Maximum="100" Value="0" Foreground="#4CAF50" Background="#2A2A35" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Column="1">
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Weather &amp; Environment" Foreground="#A0A0B0" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="기온" Foreground="#707080" FontSize="12"/>
                            <TextBlock x:Name="txtTemperature" Text="- °C" Foreground="White" FontSize="24" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="강수량" Foreground="#707080" FontSize="12"/>
                            <TextBlock x:Name="txtRainfall" Text="- mm/h" Foreground="White" FontSize="24" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="System Status" Foreground="#A0A0B0" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>

                    <TextBlock Text="노면 상태" Foreground="#707080" FontSize="12" Margin="0,0,0,5"/>
                    <Border x:Name="bdRoadCondition" Background="#2D2D44" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                        <TextBlock x:Name="txtRoadCondition" Text="대기 중" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="활성 제어 모드" Foreground="#707080" FontSize="12" Margin="0,0,0,5"/>
                    <Border BorderBrush="#FF3B30" BorderThickness="1" Background="#201010" CornerRadius="5" Padding="10">
                        <TextBlock x:Name="txtActiveControl" Text="정상 작동 중" Foreground="#4CAF50" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" VerticalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="Manual Control &amp; Speed" Foreground="#A0A0B0" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>

                    <Button x:Name="btnToggleBlackIce" Content="블랙아이스 모드 강제 실행" Height="40" Margin="0,0,0,10" Background="#FF9500" Foreground="White"/>
                    <Button x:Name="btnTriggerWrongWay" Content="🚨 역주행 시뮬레이션 발생" Height="40" Margin="0,0,0,25" Background="#FF3B30" Foreground="White"/>

                    <TextBlock Text="시뮬레이션 배속 설정" Foreground="#707080" FontSize="12" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnSpeed1x" Grid.Column="0" Content="1x (정상)" Height="35" Margin="0,0,5,0" Click="BtnSpeed1x_Click"/>
                        <Button x:Name="btnSpeed2x" Grid.Column="1" Content="2x" Height="35" Margin="5,0,5,0" Click="BtnSpeed2x_Click"/>
                        <Button x:Name="btnSpeed4x" Grid.Column="2" Content="4x" Height="35" Margin="5,0,0,0" Click="BtnSpeed4x_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>